{
  "name": "@repo/shared",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schemas/configurator": {
      "types": "./dist/schemas/configurator.d.ts",
      "default": "./dist/schemas/configurator.js"
